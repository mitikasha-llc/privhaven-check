{
  "name": "privhaven-check",
  "version": "0.1.1",
  "description": "Engine-free, offline verifier for PrivHaven compliance reports. Confirms a report against your own copy of the file using public algorithms only. No PrivHaven engine, no upload.",
  "type": "module",
  "bin": {
    "privhaven-check": "bin/privhaven-check.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src",
    "rulesets",
    "bin",
    "web",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test",
    "make-fixture": "node scripts/make-fixture.mjs",
    "build:html": "node scripts/build-html.mjs"
  },
  "keywords": [
    "privhaven",
    "compliance",
    "pii",
    "redaction",
    "gdpr",
    "audit",
    "verifier",
    "evidence",
    "sha256",
    "reproducible"
  ],
  "author": "Mitikasha LLC",
  "license": "MIT",
  "homepage": "https://github.com/mitikasha-llc/privhaven-check#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mitikasha-llc/privhaven-check.git"
  },
  "bugs": {
    "url": "https://github.com/mitikasha-llc/privhaven-check/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {}
}
